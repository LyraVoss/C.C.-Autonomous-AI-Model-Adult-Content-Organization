# Configuration template for C.C. Autonomous AI Model Organization

# AI APIs
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Payment Processing
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Social Media APIs
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Database
DATABASE_URL=postgresql://user:password@localhost/cc_ai_db
# Or for MongoDB: mongodb://localhost:27017/cc_ai_db

# Streaming
STREAMING_PLATFORM_API_KEY=your_streaming_platform_key
STREAMING_URL=rtmp://your.streaming.server/live

# Application Settings
DEBUG=True
LOG_LEVEL=INFO
SECRET_KEY=your_secret_key_here
MAX_CREATORS=50
SESSION_TIMEOUT=3600

# Content Generation
CONTENT_GENERATION_ENABLED=True
AUTO_POSTING_ENABLED=True
MODERATION_ENABLED=True